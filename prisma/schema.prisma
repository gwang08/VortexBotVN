generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

/// User profile - tracks all Telegram users who interact with the bot
model User {
  id            BigInt    @id @map("telegram_id")
  username      String?
  firstName     String?   @map("first_name")
  profitTarget  Float?    @map("profit_target")
  isVip         Boolean   @default(false) @map("is_vip")
  source        String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  followUp      FollowUp?

  @@map("users")
}

/// Telegraf session storage - one row per Telegram user
model Session {
  id        String   @id
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sessions")
}

/// Admin-created referral tracking links
model TrackingLink {
  id        Int      @id @default(autoincrement())
  source    String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("tracking_links")
}

/// Scheduled follow-up messages for non-VIP users
model FollowUp {
  id        Int      @id @default(autoincrement())
  userId    BigInt   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  startedAt DateTime @default(now()) @map("started_at")
  sent6h    Boolean  @default(false) @map("sent_6h")
  sent24h   Boolean  @default(false) @map("sent_24h")

  @@map("follow_ups")
}
